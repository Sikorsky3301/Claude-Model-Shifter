---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Claude Shifter — a gear-shifter for your Claude Code model',
  description = 'Shift your Claude Code model like a car. Drag the knob or tap a gear — Claude Shifter types /model for you.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon.png" />
  </head>
  <body>
    <slot />
    <script type="module" src="/scripts/interactions.js"></script>
  </body>
</html>
