---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Claude Shifter — Checkout">
  <main class="buy-page">
    <div class="wrap buy-inner">
      <a class="brand" href="/">
        <img src="/icon.png" alt="Claude Shifter logo" width="32" height="32" />
        <span>CLAUDE SHIFTER</span>
      </a>
      <div class="buy-card glass">
        <p class="eyebrow">Checkout</p>
        <h1>Payments aren't connected yet</h1>
        <p class="body">
          This is a placeholder page. Once a payment provider is wired up here, this is
          where checkout will happen.
        </p>
        <a class="btn btn-ghost" href="/">← Back to Claude Shifter</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .buy-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 0;
  }
  .buy-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    text-align: center;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2.5px;
  }
  .brand img { border-radius: 50%; display: block; }
  .buy-card {
    max-width: 480px;
    border-radius: var(--radius-lg);
    padding: 44px 36px;
  }
  .buy-card h1 {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 700;
    letter-spacing: -.5px;
    margin: 12px 0 16px;
  }
  .buy-card .body {
    font-size: 15px;
    margin-bottom: 30px;
  }
</style>
