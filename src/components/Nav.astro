---
---
<header class="nav" data-nav>
  <div class="wrap nav-inner">
    <a class="brand" href="/">
      <img src="/icon.png" alt="Claude Shifter logo" width="26" height="26" />
      <span>CLAUDE SHIFTER</span>
    </a>
    <a href="/buy" class="nav-download">Download for Windows</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background var(--micro), border-color var(--micro), box-shadow var(--micro);
  }
  .nav.scrolled {
    background: var(--panel);
    backdrop-filter: blur(20px) saturate(130%);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    border-bottom-color: var(--line);
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2.5px;
  }
  .brand img { border-radius: 50%; display: block; }
  .nav-download {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-decoration: none;
    color: var(--accent);
    background: rgba(180,156,252,.06);
    border: 1.5px solid rgba(180,156,252,.55);
    border-radius: 999px;
    padding: 8px 16px;
    transition: background var(--micro), border-color var(--micro), box-shadow var(--micro), transform var(--micro);
  }
  .nav-download:hover {
    background: rgba(180,156,252,.16);
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(180,156,252,.3);
    transform: translateY(-1px);
  }

  @media (max-width: 600px) {
    .nav-inner { padding-top: 10px; padding-bottom: 10px; gap: 10px; }
    .nav-download { font-size: 11px; padding: 7px 12px; white-space: nowrap; }
  }
  @media (max-width: 400px) {
    .brand span { display: none; }
  }
</style>
