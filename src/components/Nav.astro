---
---
<header class="nav" data-nav>
  <div class="wrap nav-inner">
    <a class="brand" href="/">
      <img src="/icon.png" alt="Claude Shifter logo" width="26" height="26" />
      <span>CLAUDE SHIFTER</span>
    </a>
    <a href="https://github.com/Sikorsky3301/Claude-Model-Shifter" target="_blank" rel="noopener noreferrer" class="nav-download">
      <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
      </svg>
      GitHub
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background var(--micro), border-color var(--micro), box-shadow var(--micro);
  }
  .nav.scrolled {
    background: var(--panel);
    backdrop-filter: blur(20px) saturate(130%);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    border-bottom-color: var(--line);
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2.5px;
  }
  .brand img { border-radius: 50%; display: block; }
  .nav-download {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-decoration: none;
    color: var(--accent);
    background: rgba(180,156,252,.06);
    border: 1.5px solid rgba(180,156,252,.55);
    border-radius: 999px;
    padding: 8px 16px;
    transition: background var(--micro), border-color var(--micro), box-shadow var(--micro), transform var(--micro);
  }
  .nav-download:hover {
    background: rgba(180,156,252,.16);
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(180,156,252,.3);
    transform: translateY(-1px);
  }

  @media (max-width: 600px) {
    .nav-inner { padding-top: 10px; padding-bottom: 10px; gap: 10px; }
    .nav-download { font-size: 11px; padding: 7px 12px; white-space: nowrap; }
  }
  @media (max-width: 400px) {
    .brand span { display: none; }
  }
</style>
