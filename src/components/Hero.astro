---
import DashboardMockup from './DashboardMockup.astro';
---
<section class="hero" id="top">
  <div class="blob blob-a"></div>
  <div class="blob blob-b"></div>
  <div class="blob blob-c"></div>
  <div class="spotlight" data-spotlight></div>

  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="eyebrow" style="animation: fadeUp 700ms both">
        <span class="live-dot" aria-hidden="true"></span>
        A car-style model shifter for Claude Code
      </p>
      <h1 style="animation: fadeUp 700ms 80ms both, textShimmer 5s linear infinite 900ms">
        Shift your model.<br />Not your workflow.
      </h1>
      <p class="hero-sub" style="animation: fadeUp 700ms 160ms both">
        No dropdowns, no memorized flags — just grab the stick and slot it home.
        Claude Shifter locks onto your terminal and fires
        <code>/model &lt;name&gt;</code> instantly, every time you shift.
      </p>
      <div class="hero-ctas" style="animation: fadeUp 700ms 240ms both">
        <a href="https://github.com/Sikorsky3301/-Claude-Model-Shifter.git" target="_blank" rel="noopener noreferrer" class="btn download-btn">
          <svg class="win-logo" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>
        <a href="https://github.com/Sikorsky3301/-Claude-Model-Shifter.git" target="_blank" rel="noopener noreferrer" class="gh-sticker" data-gh-stars>
          <span class="gh-sticker-star">★</span>
          <span data-star-count>Star on GitHub</span>
        </a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="mockup-frame">
        <DashboardMockup mode="hero" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 120px;
    padding-bottom: 72px;
    overflow: hidden;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: .8;
    z-index: -2;
    animation: drift 18s ease-in-out infinite;
  }
  .blob-a { width: 420px; height: 420px; top: -120px; right: 6%; background: rgba(224,164,92,.22); animation-duration: 16s; }
  .blob-b { width: 360px; height: 360px; bottom: -100px; left: 4%; background: rgba(122,84,44,.20); animation-duration: 22s; animation-delay: 2s; }
  .blob-c { width: 260px; height: 260px; top: 30%; left: 40%; background: rgba(150,110,40,.18); animation-duration: 20s; animation-delay: 4s; }

  /* Follows the cursor -- position set via --mx/--my in interactions.js */
  .spotlight {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(560px circle at var(--mx, 50%) var(--my, 15%), rgba(224,164,92,.16), transparent 62%);
    transition: background 120ms linear;
  }

  .hero-inner {
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-copy .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulseDot 2s ease-out infinite;
  }
  .hero-copy h1 {
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 1.08;
    margin: 14px 0 18px;
    background: linear-gradient(100deg, var(--text) 35%, var(--accent) 50%, var(--text) 65%);
    background-size: 250% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }
  .hero-sub {
    max-width: 440px;
    font-size: 16px;
    margin-bottom: 30px;
  }
  .hero-sub code {
    font-family: var(--font-mono);
    background: rgba(255,255,255,.06);
    padding: 2px 6px;
    border-radius: 5px;
    color: var(--text);
  }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .download-btn {
    font-size: 15px;
    padding: 15px 28px;
    background: rgba(224,164,92,.06);
    border: 1.5px solid rgba(224,164,92,.55);
    color: var(--accent);
    animation: ctaPulse 3.2s ease-in-out infinite;
  }
  .download-btn:hover {
    background: rgba(224,164,92,.16);
    border-color: var(--accent);
    box-shadow: 0 0 26px rgba(224,164,92,.35);
    transform: translateY(-2px);
    animation-play-state: paused;
  }
  .download-btn:active { transform: translateY(0); }
  .win-logo { flex-shrink: 0; }

  /* Sticker-style "star on GitHub" badge -- sits slightly rotated like a sticker,
     straightens and lifts on hover */
  .gh-sticker {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .5px;
    text-decoration: none;
    color: var(--text);
    background: var(--slab, #0a0a0d);
    border: 1.5px solid var(--line-strong);
    border-radius: 10px;
    padding: 12px 18px;
    transform: rotate(-3deg);
    box-shadow: 0 6px 16px rgba(0,0,0,.4);
    transition: transform var(--micro), border-color var(--micro), box-shadow var(--micro), background var(--micro);
  }
  .gh-sticker-star {
    color: #f6c945;
    font-size: 15px;
    text-shadow: 0 0 8px rgba(246,201,69,.6);
  }
  .gh-sticker:hover {
    transform: rotate(0deg) translateY(-2px);
    border-color: rgba(246,201,69,.6);
    box-shadow: 0 10px 24px rgba(0,0,0,.5), 0 0 20px rgba(246,201,69,.15);
    background: #111116;
  }

  .hero-visual { display: flex; justify-content: center; }

  /* Floating glow frame around the dashboard mockup */
  .mockup-frame {
    position: relative;
    animation: floatY 6s ease-in-out infinite;
  }
  .mockup-frame::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: calc(var(--radius-lg) + 3px);
    background: conic-gradient(from 0deg, rgba(224,164,92,.65), transparent 28%, transparent 72%, rgba(224,164,92,.65));
    filter: blur(16px);
    opacity: .55;
    z-index: -1;
    animation: spin360 7s linear infinite;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero { padding-top: 120px; }
    .hero-visual { min-width: 0; }
    .mockup-frame { width: 100%; max-width: 420px; }
  }
</style>
