---
interface Props {
  mode: 'hero' | 'showcase';
}
const { mode } = Astro.props;
const gradId = `chromeGrad-${mode}`;
---
<div class:list={['mockup', mode]} data-dashboard={mode}>
  <div class="telemetry glass">
    <div class="gauge-wrap">
      <svg class="gauge" viewBox="0 0 200 120">
        <path d="M 15 105 A 85 85 0 0 1 185 105" class="gauge-track" />
        <path d="M 15 105 A 85 85 0 0 1 185 105" class="gauge-redline" pathLength="100"
              stroke-dasharray="18 100" stroke-dashoffset="-82" />
        <g class="gauge-ticks">
          <text x="15" y="112">0</text>
          <text x="47" y="45">2</text>
          <text x="100" y="25">4</text>
          <text x="153" y="45">6</text>
          <text x="185" y="112">8</text>
        </g>
        <line data-needle x1="100" y1="105" x2="100" y2="30" class="needle" />
        <circle cx="100" cy="105" r="6" class="needle-hub" />
      </svg>
      <div class="gauge-caption">TOK/MIN &times;1000</div>
    </div>
    <div class="readout">
      <div class="readout-gear" data-gear-num>N</div>
      <div class="readout-label" data-gear-label>NEUTRAL</div>
      <div class="readout-cmd" data-cmd>&nbsp;</div>
    </div>
  </div>

  <div class="gear-row">
    <button class="gbtn" data-gbtn="haiku"><b>1</b><span>Haiku</span></button>
    <button class="gbtn" data-gbtn="sonnet1m"><b>3</b><span>Sonnet 1M</span></button>
    <button class="gbtn" data-gbtn="fable"><b>5</b><span>Fable</span></button>
  </div>

  <div class="knob-stage" data-stage>
    <svg class="track" viewBox="0 0 300 220" preserveAspectRatio="xMidYMid meet">
      <defs>
        <radialGradient id={gradId} cx="38%" cy="28%" r="80%">
          <stop offset="0%" stop-color="#ffffff" />
          <stop offset="40%" stop-color="#cdd2d8" />
          <stop offset="75%" stop-color="#99a1aa" />
          <stop offset="100%" stop-color="#666d75" />
        </radialGradient>
      </defs>
      <circle cx="150" cy="110" r="104" fill={`url(#${gradId})`} class="disc" />
      <line x1="95" y1="48" x2="95" y2="172" class="rail" />
      <line x1="150" y1="48" x2="150" y2="172" class="rail" />
      <line x1="205" y1="48" x2="205" y2="172" class="rail" />
      <line x1="95" y1="110" x2="205" y2="110" class="rail" />
    </svg>
    <div class="knob" data-knob>
      <div class="knob-top"></div>
      <svg class="knob-pattern" viewBox="0 0 60 60">
        <line x1="18" y1="22" x2="18" y2="40" class="pb-line" />
        <line x1="30" y1="22" x2="30" y2="40" class="pb-line" />
        <line x1="42" y1="22" x2="42" y2="40" class="pb-line" />
        <line x1="18" y1="31" x2="42" y2="31" class="pb-line" />
        <text x="18" y="17" class="pb-num">1</text>
        <text x="30" y="17" class="pb-num">3</text>
        <text x="42" y="17" class="pb-num">5</text>
        <text x="18" y="49" class="pb-num">2</text>
        <text x="30" y="49" class="pb-num">4</text>
        <text x="42" y="49" class="pb-num">R</text>
      </svg>
    </div>
  </div>

  <div class="gear-row">
    <button class="gbtn" data-gbtn="sonnet"><b>2</b><span>Sonnet</span></button>
    <button class="gbtn" data-gbtn="opus"><b>4</b><span>Opus</span></button>
    <button class="gbtn" data-gbtn="default"><b>R</b><span>Default</span></button>
  </div>

  {mode === 'showcase' && (
    <button class="mute-toggle" data-mute-toggle aria-pressed="false" aria-label="Toggle gear sounds">
      &#128266;
    </button>
  )}
</div>

<style>
  .mockup {
    border-radius: var(--radius-lg);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    background: var(--panel);
    backdrop-filter: blur(20px) saturate(130%);
    -webkit-backdrop-filter: blur(20px) saturate(130%);
    border: 1px solid var(--line);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.07), 0 24px 60px rgba(0,0,0,.55);
  }
  .mockup.hero { max-width: 420px; }
  .mockup.showcase { max-width: 480px; margin: 0 auto; }

  .telemetry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--slab);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 10px 18px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05), inset 0 0 24px rgba(0,0,0,.5);
  }
  .gauge-wrap { display: flex; flex-direction: column; align-items: center; }
  .gauge { width: 140px; height: auto; }
  .gauge-track { fill: none; stroke: rgba(255,255,255,.14); stroke-width: 7; stroke-linecap: round; }
  .gauge-redline { fill: none; stroke: var(--red); stroke-width: 7; stroke-linecap: round; opacity: .9; }
  .gauge-ticks text { fill: #b9bec6; font-size: 9px; text-anchor: middle; font-family: var(--font-mono); }
  .needle {
    stroke: #e8ebee; stroke-width: 3; stroke-linecap: round;
    transform-origin: 100px 105px;
    transition: transform .6s var(--snap-ease);
    filter: drop-shadow(0 0 3px rgba(255,255,255,.35));
  }
  .needle-hub { fill: var(--chrome-2); }
  .gauge-caption { font-size: 8px; letter-spacing: 2px; color: var(--muted); margin-top: -6px; font-family: var(--font-mono); }

  .readout { text-align: right; min-width: 0; }
  .readout-gear {
    font-family: var(--font-display);
    font-size: 40px; font-weight: 700; line-height: 1; letter-spacing: -1px;
    color: var(--accent);
    text-shadow: 0 0 18px rgba(180,156,252,.5);
  }
  .readout-label {
    font-family: var(--font-display);
    font-size: 12px; font-weight: 600; letter-spacing: 3px;
    color: var(--accent); opacity: .9; margin-top: 2px;
  }
  .readout-cmd {
    font-size: 11px; color: var(--muted); font-family: var(--font-mono);
    margin-top: 4px; min-height: 14px; white-space: nowrap;
  }

  .gear-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .gbtn {
    background: linear-gradient(180deg, var(--btn-hi) 0%, var(--btn-lo) 100%);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 8px 4px;
    color: var(--muted);
    font-family: inherit;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.09);
    transition: color var(--micro), border-color var(--micro), box-shadow var(--micro), transform var(--micro);
  }
  .gbtn b { font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--text); }
  .gbtn span { font-family: var(--font-display); font-size: 8px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; }
  .gbtn:hover { border-color: var(--line-strong); transform: translateY(-1px); }
  .gbtn.active {
    border-color: rgba(180,156,252,.55);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.1), 0 0 14px rgba(180,156,252,.28);
  }
  .gbtn.active b { color: var(--accent); }

  .knob-stage {
    position: relative;
    aspect-ratio: 300 / 220;
  }
  .track { position: absolute; inset: 0; width: 100%; height: 100%; }
  .disc { filter: drop-shadow(0 10px 20px rgba(0,0,0,.6)); }
  .rail { stroke: #0a0a0c; stroke-width: 26; stroke-linecap: round; }

  .knob {
    position: absolute;
    left: 50%; top: 50%;
    width: 15%; aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    cursor: grab;
    touch-action: none;
    z-index: 5;
    transition:
      left var(--snap-time) var(--snap-ease),
      top var(--snap-time) var(--snap-ease),
      transform 150ms cubic-bezier(.4, 0, .2, 1);
  }
  .knob.dragging {
    cursor: grabbing;
    transition: transform 150ms cubic-bezier(.4, 0, .2, 1);
    transform: translate(-50%, -50%) scale(1.1);
  }
  @keyframes knobSeat {
    0%   { transform: translate(-50%, -50%) scale(1.1); }
    55%  { transform: translate(-50%, -50%) scale(.94); }
    100% { transform: translate(-50%, -50%) scale(1); }
  }
  .knob.seating { animation: knobSeat 240ms cubic-bezier(.34, 1.4, .5, 1) both; }
  .knob-top {
    position: absolute; inset: 0;
    border-radius: 50%;
    background: radial-gradient(55% 55% at 35% 26%, #55555e 0%, #232327 45%, #0b0b0e 100%);
    border: 2px solid #3c4148;
    box-shadow: inset 0 3px 6px rgba(255,255,255,.18), inset 0 -8px 14px rgba(0,0,0,.7), 0 8px 18px rgba(0,0,0,.7);
    transition: box-shadow var(--micro);
  }
  .knob.dragging .knob-top {
    box-shadow: inset 0 3px 6px rgba(255,255,255,.18), inset 0 -8px 14px rgba(0,0,0,.7), 0 16px 30px rgba(0,0,0,.8);
  }
  .knob-pattern { position: absolute; inset: 10%; width: 80%; height: 80%; pointer-events: none; }
  .pb-line { stroke: #d6dade; stroke-width: 2; stroke-linecap: round; }
  .pb-num { fill: #eceff2; font-size: 9px; font-weight: 700; font-family: "Segoe UI", system-ui, sans-serif; text-anchor: middle; }

  .mute-toggle {
    position: absolute;
    top: 12px; right: 12px;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,.06);
    border: 1px solid var(--line);
    color: var(--text);
    font-size: 14px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background var(--micro), border-color var(--micro);
  }
  .mute-toggle.muted { opacity: .45; }
  .mute-toggle:hover { border-color: var(--line-strong); }

  /* Mobile only -- lets the mockup shrink below its 420px desktop max-width
     instead of overflowing a narrow flex parent. Desktop rules above are untouched. */
  @media (max-width: 900px) {
    .mockup { width: 100%; }
  }

  @media (max-width: 420px) {
    .mockup { padding: 14px; gap: 10px; }
    .telemetry { padding: 8px 12px; }
    .gauge { width: 108px; }
    .readout-gear { font-size: 30px; }
    .readout-label { font-size: 10px; letter-spacing: 2px; }
    .readout-cmd { white-space: normal; }
    .gear-row { gap: 6px; }
    .gbtn { padding: 7px 3px; }
    .gbtn b { font-size: 14px; }
    .gbtn span { font-size: 7px; letter-spacing: 1px; }
  }
</style>
