---
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap footer-inner" data-reveal>
    <a class="brand" href="/">
      <img src="/icon.png" alt="Claude Shifter logo" width="28" height="28" />
      <span>CLAUDE SHIFTER</span>
    </a>
    <p class="tagline">A car-style gear shifter for your Claude Code model.</p>
    <div class="footer-links">
      <a href="/buy">Download for Windows</a>
    </div>
    <p class="copyright">&copy; {year} Claude Shifter. Not affiliated with Anthropic.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    padding: 48px 0 36px;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2.5px;
    transition: transform var(--micro), filter var(--micro);
  }
  .brand:hover {
    transform: rotate(8deg);
    filter: drop-shadow(0 0 10px rgba(180,156,252,.5));
  }
  .brand img { border-radius: 50%; display: block; }
  .tagline { font-size: 13px; margin: 0; }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a {
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    transition: color var(--micro);
  }
  .footer-links a:hover { color: var(--text); }
  .copyright {
    font-size: 12px;
    color: #5f6169;
    margin: 8px 0 0;
  }
</style>
